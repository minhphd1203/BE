								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{inspectorToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "http://localhost:3000/api/inspector/v1/bikes/{{pendingBikeId}}/start",
							"protocol": "http",
							"host": ["localhost"],
							"port": "3000",
							"path": ["api", "inspector", "v1", "bikes", "{{pendingBikeId}}", "start"]
						},
						"description": "Bắt đầu kiểm định (chuyển status sang in_progress)"
