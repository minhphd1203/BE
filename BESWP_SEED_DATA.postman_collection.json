					"response": []
				},
				{
					"name": "6. Submit Inspection - PASSED",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data) {",
									"    pm.collectionVariables.set('lastInspectionId', jsonData.data.id);",
									"    console.log('✅ Inspection submitted successfully!');",
