							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{inspectorToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
