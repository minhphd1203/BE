						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"passed\",\n  \"overallCondition\": \"good\",\n  \"frameCondition\": \"excellent\",\n  \"brakeCondition\": \"good\",\n  \"drivetrainCondition\": \"fair\",\n  \"wheelCondition\": \"good\",\n  \"inspectionNote\": \"Xe trong tình trạng tốt, các bộ phận hoạt động bình thường. Phanh đã được kiểm tra kỹ lưỡng.\"\n}"
						},
						"url": {
							"raw": "http://localhost:3000/api/inspector/v1/bikes/{{pendingBikeId}}/inspect",
							"protocol": "http",
							"host": ["localhost"],
							"port": "3000",
							"path": ["api", "inspector", "v1", "bikes", "{{pendingBikeId}}", "inspect"]
						},
						"description": "Submit form kiểm định với kết quả PASSED (đạt)"
					},
					"response": []
				},
				{
					"name": "6b. Submit Inspection - FAILED",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data) {",
