# Environment Variables Template
# Copy this to .env and fill in your values

# Server Port
PORT=3000

# Database Connection
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:yourpassword@localhost:5432/bike_exchange
DATABASE_URL=postgresql://neondb_owner:npg_Dp3hKNBX5AzL@ep-autumn-frog-a17r6yg2-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT Secret (for token generation)
# Change this to a strong secret in production!
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Node Environment
NODE_ENV=development

# App URL (VNPay + link đầy đủ cho ảnh/video upload tin bán xe: /uploads/bikes/...)
APP_URL=http://localhost:3000

# ============= VNPAY CONFIGURATION =============
# Lấy thông tin từ: https://sandbox.vnpayment.vn/merchantv2/

# Terminal ID - mã định danh merchant
VNP_TMNCODE=U3D16BLI

# Secret key để tạo chữ ký bảo mật
VNP_SECRET=WCTQD46TD3NNSOKGECO3FJWWESPHX7DZ

# URL VNPay redirect buyer về sau khi thanh toán
# - Nếu dùng backend handler: http://localhost:3000/api/payment/v1/vnpay-return
# - Nếu dùng frontend SPA (React/Vue): http://localhost:5173/payment/result
VNP_RETURN_URL=http://localhost:3000/api/payment/v1/vnpay-return

# Sandbox test: https://sandbox.vnpayment.vn
# Production:   https://pay.vnpay.vn
VNP_HOST=https://sandbox.vnpayment.vn
