					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.length > 0) {",
									"    pm.collectionVariables.set('pendingBikeId', jsonData.data[0].id);",
									"    console.log('Saved bike ID:', jsonData.data[0].id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
